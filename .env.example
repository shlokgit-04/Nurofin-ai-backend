# === Backend Environment Variables ===

# Required for production
SECRET_KEY=change-me-to-a-secure-random-string
DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname

# CORS - comma-separated list of allowed origins
# Production: https://your-app.pages.dev
# Local dev: http://localhost:3000
CORS_ORIGINS=https://your-app.pages.dev

# Frontend URL (for Google OAuth redirect URIs)
# Production: https://your-app.pages.dev
# Local dev: http://localhost:3000
FRONTEND_URL=https://your-app.pages.dev

# AI Engine URL (for meeting MOM analysis)
# Production: https://ai-engin.onrender.com
# Local dev: http://localhost:8001
AI_ENGINE_URL=https://ai-engin.onrender.com

# Google Calendar Integration (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_PROJECT_ID=your-google-project-id

# App Environment (development|production)
APP_ENV=development

# PostgreSQL (used only if DATABASE_URL is not set)
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=qwerty
POSTGRES_DB=nurofin_db
POSTGRES_PORT=5432

# SQLite fallback (set to "true" to use SQLite instead of PostgreSQL)
# USE_SQLITE=true
