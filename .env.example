# === Backend Environment Variables ===

# Required for production
SECRET_KEY=change-me-to-a-secure-random-string
DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname

# CORS - comma-separated list of allowed origins
# Example: https://your-app.vercel.app,http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Frontend URL (for Google OAuth redirect URIs)
FRONTEND_URL=http://localhost:3000

# AI Engine URL (for meeting MOM analysis)
AI_ENGINE_URL=http://localhost:8001

# Google Calendar Integration (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_PROJECT_ID=your-google-project-id

# App Environment (development|production)
APP_ENV=development

# PostgreSQL (used only if DATABASE_URL is not set)
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=qwerty
POSTGRES_DB=nurofin_db
POSTGRES_PORT=5432

# SQLite fallback (set to "true" to use SQLite instead of PostgreSQL)
# USE_SQLITE=true
